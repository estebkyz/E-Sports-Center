# Copia este archivo como backend/.env y completa los valores

DJANGO_SECRET_KEY=cambia-esta-clave-por-una-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos — SQL Server
DB_NAME=esports_center
DB_HOST=localhost
DB_PORT=1433
DB_TRUSTED=yes

# Solo si DB_TRUSTED=no (autenticación SQL):
# DB_USER=sa
# DB_PASSWORD=tu_contraseña
